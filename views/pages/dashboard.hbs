<link rel="stylesheet" href="/css/dashboard.css">

<div class="app-layout">
    <aside class="navbar">
        <a href="/dashboard" class="navbar-brand">
            <i class="fa-solid fa-building-columns"></i>
            <span>LabMate</span>
        </a>

        <ul class="navbar-nav" data-testid="navbar-nav">
            <li><a href="/dashboard" class="active" data-testid="link-dashboard"><i class="fa-solid fa-house"></i>
                    <span>Dashboard</span></a></li>
            <li><a href="/slot-availability" data-testid="link-lab-availability"><i
                        class="fa-solid fa-magnifying-glass"></i> <span>Lab Availability</span></a></li>
            {{#if user.isTechnician}}
            <li><a href="/reserve-for-student" data-testid="link-reserve-for-student"><i class="fa-solid fa-plus"></i>
                    <span>Reserve for Student</span></a></li>
            {{/if}}
            <li><a href="/manage-reservations" data-testid="link-manage-reservations"><i
                        class="fa-regular fa-clipboard"></i> <span>Manage Reservations</span></a></li>
            {{#if user.isTechnician}}
            <li><a href="/manage-no-shows" data-testid="link-manage-no-shows"><i class="fa-solid fa-user-xmark"></i>
                    <span>Manage No-Shows</span></a></li>
            {{/if}}
        </ul>

        <div class="navbar-logout">
            <a href="/logout" data-testid="link-logout"><i class="fa-solid fa-right-from-bracket"></i> <span>Log
                    out</span></a>
        </div>
    </aside>

    <div class="main-content">
        <div class="top-bar">
            <div class="top-bar-left">
                <h1>Dashboard</h1>
                <p class="date-text"><b>{{currentDate}}</b></p>
            </div>
            <div class="top-bar-right" onclick="location.href='/user-profile'">
                <div class="user-info">
                    <div class="user-name" data-testid="text-user-name">{{user.firstName}} {{user.lastName}}</div>
                    <div class="user-role" data-testid="text-user-role">{{user.role}}</div>
                </div>
                <div class="user-avatar" data-testid="user-avatar">
                    {{user.initials}}
                </div>
            </div>
        </div>

        <div class="main-body">
            <div class="dashboard-content">
                <div class="greeting-banner">
                    <h2>Hello, {{user.firstName}}</h2>
                    <p>Have a nice day!</p>
                </div>

                <form action="/dashboard" method="GET" class="search-input">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="search-room" name="search" placeholder="Search">
                </form>

                <div class="info-row">
                    <!-- left: upcoming reservations -->
                    <div class="info-card reservations-card">
                        <h3>Upcoming Reservations</h3>
                        <div class="reservations-list">
                            {{#each reservations}}
                            <div class="reservation-item">
                                <span class="res-lab">{{labName}} - {{building}}</span>
                                <span class="res-details">{{dateDisplay}} • {{timeSlot}} • Seat {{seatNumber}}</span>
                            </div>
                            {{else}}
                            <p>No upcoming reservations.</p>
                            {{/each}}
                        </div>
                        {{#if hasReservations}}
                        <a class="view-all" href="/manage-reservations">View all</a>
                        {{/if}}
                    </div>

                    <!-- right: live lab availability -->
                    <div class="info-card availability-card">
                        <h3>Current Lab Availability</h3>
                        <div class="availability-list">
                            {{#each labAvailability}}
                            <div class="lab-item">
                                <span class="lab-name">{{labName}}:</span>
                                <span class="lab-seats">{{available}}/{{capacity}}</span>
                            </div>
                            {{else}}
                            <p>No labs available.</p>
                            {{/each}}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
