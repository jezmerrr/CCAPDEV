<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
            rel="stylesheet">
        <link
            href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
            rel="stylesheet">

        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <!-- Used for icons -->
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/css/auth.css">
        <link rel="stylesheet" href="/css/navbar.css">
        <link rel="stylesheet" href="/css/user-profile.css">

        <title>View Profile</title>
    </head>

    <body>
        <div class="app-layout">
            <nav class="navbar">
                <a href="/dashboard" class="navbar-brand">
                    <i class="fa-solid fa-building-columns"></i>
                    <span>LabMate</span>
                </a>

                <ul class="navbar-nav" data-testid="navbar-nav">
                    <li><a href="/dashboard" data-testid="link-dashboard"><i class="fa-solid fa-house"></i> <span>Dashboard</span></a></li>
                    <li><a href="/slot-availability" data-testid="link-lab-availability"><i class="fa-solid fa-magnifying-glass"></i> <span>Lab Availability</span></a></li>
                    <li><a href="/reserve-for-student" data-testid="link-reserve-for-student"><i class="fa-solid fa-plus"></i> <span>Reserve for Student</span></a></li>
                    <li><a href="/manage-reservations" data-testid="link-manage-reservations"><i class="fa-regular fa-clipboard"></i> <span>Manage Reservations</span></a></li>
                    {{#if user.isTechnician}}
                    <li><a href="/manage-no-shows" data-testid="link-manage-no-shows"><i class="fa-solid fa-user-xmark"></i> <span>Manage No-Shows</span></a></li>
                    {{/if}}
                </ul>

                <div class="navbar-logout">
                    <a href="/login" data-testid="link-logout"><i class="fa-solid fa-right-from-bracket"></i> <span>Log out</span></a>
                </div>
            </nav>

            <div class="main-content">

                <section class="user-content">
                    
                    <section class="user-info">
                        <h3 class="user-name">Name: {{user.firstName}} {{user.lastName}}</h3>
                        <h3 class="user-email">Email: {{user.email}}</h3>

                        <h3 class="description">Description:</h3>
                        <textarea class="description-box" readonly>{{user.description}}</textarea>
                    </section>

                    <section class="user-profile-pic">
                        <img class="profile-pic" src="{{user.profilePicture}}" alt="user's profile pic">
                        <h3 class="account-type">{{user.role}}</h3>

                        <button class="edit-profile" id="edit-profile-button">Edit Profile</button>
                    </section>

                </section>

                <h2 class="reservation-title">Upcoming Reservations</h2>

                <section class="user-reservations">
                    <div class="reservation-header">
                        <span>Lab</span>
                        <span>Date</span>
                        <span>Time Slot</span>
                        <span>Status</span>
                    </div>
                    {{#each reservation}}
                        <div class="reservation-rows">
                            <span>{{this.lab.labName}}</span>
                            <span>{{this.date}}</span>
                            <span>{{this.timeSlot}}</span>
                            <span>{{this.status}}</span>
                        </div>
                    {{/each}}
                </section>
            </div>
        </div>

        <!--Modal for edit profile-->
        <div id="edit-profile-modal" class="modal">
            <!--Modal Content-->
            <div class="modal-content">
                <span class="close">&times;</span>
                <form class="user-information" action="/user-profile" method="POST">
                    <div class="form-group">
                        <label for="uName">Name: </label>
                        <input type="text" id="uName" name="name" value="{{user.firstName}} {{user.lastName}}">
                    </div>

                    <div class="form-group">
                        <label for="uEmail">Email: </label>
                        <input type="text" id="uEmail" name="email" value="{{user.email}}">
                    </div>

                    <div class="form-group">
                        <label for="uDescription">Description: </label>
                        <textarea class="description-box" name="description" id="uDescription">{{user.description}}</textarea>
                    </div>

                    <button type="submit" class="edit-profile">Save</button>
                </form>
            </div>
        </div>

        <!--js script on edit user profile-->
        <script src="/js/edit-user.js"></script>
    </body>
</html>