<link rel="stylesheet" href="/css/reservation.css">

{{#if reservation}}
<div class="app-layout">
    <aside class="navbar">
        <a href="/dashboard" class="navbar-brand">
            <i class="fa-solid fa-building-columns"></i>
            <span>LabMate</span>
        </a>

        <ul class="navbar-nav" data-testid="navbar-nav">
            <li><a href="/dashboard" data-testid="link-dashboard"><i class="fa-solid fa-house"></i> <span>Dashboard</span></a></li>
            <li><a href="/slot-availability" data-testid="link-lab-availability"><i class="fa-solid fa-magnifying-glass"></i> <span>Lab Availability</span></a></li>
            <li><a href="/reserve-for-student" data-testid="link-reserve-for-student"><i class="fa-solid fa-plus"></i> <span>Reserve for Student</span></a></li>
            <li><a href="/manage-reservations" class="active" data-testid="link-manage-reservations"><i class="fa-regular fa-clipboard"></i> <span>Manage Reservations</span></a></li>
            {{#if user.isTechnician}}
            <li><a href="/manage-no-shows" class="active" data-testid="link-manage-no-shows"><i class="fa-solid fa-user-xmark"></i> <span>Manage No-Shows</span></a></li>
            {{/if}}
        </ul>

        <div class="navbar-logout">
            <a href="/login" data-testid="link-logout"><i class="fa-solid fa-right-from-bracket"></i> <span>Log out</span></a>
        </div>
    </aside>

    <div class="main-content">
        <div class="top-bar">
            <div class="top-bar-left">
                <h1>Edit Reservation</h1>
            </div>
            <div class="top-bar-right" onclick="location.href='/user-profile'">
                <div class="user-info">
                    <div class="user-name" data-testid="text-user-name">
                        {{user.firstName}} {{user.lastName}}
                    </div>
                    <div class="user-role" data-testid="text-user-role">
                        {{user.role}}
                    </div>
                </div>
                <div class="user-avatar" data-testid="user-avatar">
                    {{user.initials}}
                </div>
            </div>
        </div>

        <div class="main-body">
            <div style="margin-bottom: 16px;">
                <a href="/manage-reservations" class="btn-secondary" data-testid="button-back-reservations">
                    <i class="fa-solid fa-arrow-left"></i> Back to Reservations
                </a>
            </div>

            <div class="edit-form-container" id="edit-form-container">
                <h2>Reservation Details</h2>

                <form id="edit-reservation-form" data-testid="form-edit-reservation" method="POST" action="/reservations/{{reservation._id}}/update">
                    <div class="edit-form-grid">
                        <div class="form-group">
                            <label for="res-id">Reservation ID</label>
                            <input
                                type="text"
                                id="res-id"
                                data-testid="input-reservation-id"
                                value="{{reservation._id}}"
                                disabled
                            >
                        </div>

                        <div class="form-group">
                            <label for="res-user">User</label>
                            <input
                                type="text"
                                id="res-user"
                                data-testid="input-reservation-user"
                                value="{{reservation.user.firstName}} {{reservation.user.lastName}}"
                                disabled
                            >
                        </div>

                        <div class="form-group">
                            <label for="res-status">Status</label>
                            <input
                                type="text"
                                id="res-status"
                                data-testid="input-reservation-status"
                                value="{{reservation.status}}"
                                disabled
                            >
                        </div>

                        <div class="form-group">
                            <label for="res-room">Room *</label>
                            <input
                                type="text"
                                id="res-room"
                                data-testid="select-room"
                                value="{{reservation.lab.labName}} - {{reservation.lab.building}}"
                                disabled
                            >
                        </div>

                        <div class="form-group">
                            <label for="res-date">Date *</label>
                            <input
                                type="date"
                                id="res-date"
                                name="date"
                                data-testid="input-date"
                                value="{{reservation.date}}"
                                required
                            >
                        </div>

                        <div class="form-group">
                            <label for="res-time-slot">Time Slot *</label>
                            <select id="res-time-slot" name="timeSlot" data-testid="select-time-slot" required>
                                <option value="">-- Select Time Slot --</option>
                                {{#each timeSlots}}
                                    <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>
                                        {{this.label}}
                                    </option>
                                {{/each}}
                            </select>
                        </div>

                        <div class="form-group full-width">
                            <label for="res-purpose">Purpose / Reason *</label>
                            <textarea
                                id="res-purpose"
                                name="purpose"
                                data-testid="textarea-purpose"
                                rows="3"
                                required
                            >{{reservation.purpose}}</textarea>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a href="/manage-reservations" class="btn-secondary" data-testid="button-cancel-edit">Cancel</a>
                        <button type="submit" class="btn-primary" data-testid="button-save-reservation">
                            <i class="fa-solid fa-floppy-disk"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{{else}}
<div id="not-found-state" class="empty-state" data-testid="not-found-state">
    <i class="fa-solid fa-circle-exclamation" style="font-size: 48px; color: var(--sage-green); margin-bottom: 12px;"></i>
    <p>Reservation not found. Please go back and try again.</p>
    <a href="/manage-reservations" class="btn-primary" style="display: inline-block; margin-top: 16px;">Back to Reservations</a>
</div>
{{/if}}

<div id="toast" class="toast"></div>

<script src="/js/reservation.js"></script>
<script src="/js/edit-reservations.js"></script>