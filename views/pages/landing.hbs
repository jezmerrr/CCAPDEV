<!-- ABOUT PAGE -->
<section class="about-page" id="about">
    <div class="ap-description">
        <h1>About the Platform</h1>
        <p>
            The DLSU Computer Lab Reservation platform is a web-based system developed to make reserving computer
            lab seats more efficient and convenient. It allows students to check available slots, book seats, and
            manage their reservations in a simple and organized way.

            Created for both students and lab technicians, the platform helps improve how lab usage is managed while
            reducing confusion and manual processes.
        </p>
    </div>

    <div class="ap-features">
        <div class="features-container">
            <h1>Key Features</h1>
            <div class="feature">
                <h3>Real-Time Availability</h3>
                <p>View current seat availability across all computer labs without needing to refresh the page.</p>
            </div>

            <div class="feature">
                <h3>Flexible Reservations</h3>
                <p>Book slots in 30-minute intervals up to 7 days in advance. Reserve multiple slots at once under a
                    single reservation.</p>
            </div>

            <div class="feature">
                <h3>Privacy Options</h3>
                <p>Choose to reserve anonymously or display your name publicly.</p>
            </div>

            <div class="feature">
                <h3>Easy Management</h3>
                <p>Edit or cancel your reservations anytime from your dashboard.</p>
            </div>
        </div>
    </div>

    <div class="ap-tech">
        <div class="tech-container">
            <h1>Technologies Used</h1>
            <div class="tech-group">
                <h3>NPM Packages</h3>
                <div class="tech-pills">
                    <span class="pill">Express</span>
                    <span class="pill">Mongoose</span>
                    <span class="pill">bcrypt</span>
                    <span class="pill">express-session</span>
                    <span class="pill">express-handlebars</span>
                </div>
            </div>
            <div class="tech-group">
                <h3>Third Party Libraries</h3>
                <div class="tech-pills">
                    <span class="pill">Font Awesome</span>
                    <span class="pill">Google Fonts</span>
                </div>
            </div>
        </div>
    </div>
</section>

