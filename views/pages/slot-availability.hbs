<link rel="stylesheet" href="/css/booking.css">

<div class="app-layout">
    <aside class="navbar">
        <a href="/dashboard" class="navbar-brand">
            <i class="fa-solid fa-building-columns"></i>
            <span>LabMate</span>
        </a>

        <ul class="navbar-nav" data-testid="navbar-nav">
            <li><a href="/dashboard" class="active" data-testid="link-dashboard"><i class="fa-solid fa-house"></i>
                    <span>Dashboard</span></a></li>
            {{#unless user.isTechnician}}
            <li><a href="/slot-availability" data-testid="link-lab-availability"><i
                        class="fa-solid fa-magnifying-glass"></i> <span>Lab Availability</span></a></li>
            {{/unless}}
            {{#if user.isTechnician}}
            <li><a href="/reserve-for-student" data-testid="link-reserve-for-student"><i class="fa-solid fa-plus"></i>
                    <span>Reserve for Student</span></a></li>
            {{/if}}
            <li><a href="/manage-reservations" data-testid="link-manage-reservations"><i
                        class="fa-regular fa-clipboard"></i> <span>Manage Reservations</span></a></li>
            {{#if user.isTechnician}}
            <li><a href="/manage-no-shows" data-testid="link-manage-no-shows"><i class="fa-solid fa-user-xmark"></i>
                    <span>Manage No-Shows</span></a></li>
            {{/if}}
        </ul>

        <div class="navbar-logout">
            <a href="/logout" data-testid="link-logout"><i class="fa-solid fa-right-from-bracket"></i> <span>Log
                    out</span></a>
        </div>
    </aside>

    <div class="main-content">
        <div class="top-bar">
            <div class="top-bar-left">
                <h1>Lab Availability</h1>
            </div>
            <div class="top-bar-right" onclick="location.href='/user-profile'">
                <div class="user-info">
                    <div class="user-name" data-testid="text-user-name">{{user.firstName}} {{user.lastName}}</div>
                    <div class="user-role" data-testid="text-user-role">{{user.role}}</div>
                </div>
                <div class="user-avatar" data-testid="user-avatar">{{user.initials}}</div>
            </div>
        </div>

        <div class="main-body">
            <div class="booking-container">
                <!-- Left Side: Building & Room Selection -->
                <div class="booking-left">
                    <div class="hall-cards" id="hall-cards">
                        <!-- Building cards rendered by JS -->
                    </div>

                    <div class="rooms-list-header">
                        <h4>Available Rooms</h4>
                    </div>

                    <div class="rooms-list" id="rooms-list">
                        <!-- Rooms will be loaded here -->
                    </div>
                </div>

                <!-- Right Side: Booking Form + Seat Availability -->
                <div class="booking-right">
                    <div class="booking-form-container">
                        <h2><i class="fa-solid fa-calendar-plus"></i> Book a Lab Slot</h2>

                        <form id="booking-form" action="/reservations/create" method="POST">
                            <input type="hidden" id="form-lab-id" name="labId">

                            <div class="booking-form-grid">
                                <div class="form-group">
                                    <label for="form-room">Room</label>
                                    <input type="text" id="form-room" placeholder="Select a room from the left" disabled>
                                </div>

                                <div class="form-group">
                                    <label for="form-date">Date *</label>
                                    <input type="date" id="form-date" name="date" required>
                                </div>

                                <div class="form-group full-width">
                                    <label>Time Slot(s) * <small class="hint">(Select one or more)</small></label>
                                    <div class="time-slot-checkboxes" id="time-slot-checkboxes">
                                        {{#each timeSlots}}
                                        <label class="slot-checkbox">
                                            <input type="checkbox" name="timeSlot" value="{{this.value}}">
                                            <span class="slot-checkbox-label">{{this.label}}</span>
                                        </label>
                                        {{/each}}
                                    </div>
                                </div>

                                <div class="form-group full-width">
                                    <label for="purpose">Purpose / Reason *</label>
                                    <textarea id="purpose" name="purpose" rows="3"
                                        placeholder="e.g., CSARCH2 Group Study Session" required></textarea>
                                </div>

                                <div class="form-group full-width checkbox-group">
                                    <label>
                                        <input type="checkbox" id="is-anonymous" name="isAnonymous">
                                        <span>Book anonymously</span>
                                    </label>
                                    <small>Your name will be hidden from other students viewing this seat</small>
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="button" class="btn-cancel" id="reset-form">
                                    <i class="fa-solid fa-rotate-left"></i> Reset
                                </button>
                                <button type="submit" class="btn-confirm" id="btn-submit" disabled>
                                    <i class="fa-solid fa-check"></i> Confirm Reservation
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Seat Availability Section -->
                    <div class="seat-availability-section" id="seat-availability-section" style="display: none;">
                        <div class="seat-availability-header">
                            <h3><i class="fa-solid fa-chair"></i> Seat Availability</h3>
                            <span class="seat-availability-info" id="seat-availability-info"></span>
                        </div>

                        <div class="seat-availability-table-wrapper">
                            <table class="seat-availability-table" id="seat-availability-table">
                                <thead>
                                    <tr>
                                        <th>Seat</th>
                                        <th>Status</th>
                                        <th>Reserved By</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="seat-table-body">
                                    <!-- Seat rows rendered by JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

<script>
    var SERVER_BUILDINGS = {{{buildings}}};
</script>
<script src="/js/slot-availability.js"></script>
