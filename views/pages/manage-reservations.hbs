<link rel="stylesheet" href="/css/reservation.css">

<div class="app-layout">
    <aside class="navbar">
        <a href="/dashboard" class="navbar-brand">
            <i class="fa-solid fa-building-columns"></i>
            <span>LabMate</span>
        </a>

        <ul class="navbar-nav" data-testid="navbar-nav">
            <li><a href="/dashboard" data-testid="link-dashboard"><i class="fa-solid fa-house"></i> <span>Dashboard</span></a></li>
            <li><a href="/slot-availability" data-testid="link-lab-availability"><i class="fa-solid fa-magnifying-glass"></i> <span>Lab Availability</span></a></li>
            {{#if user.isTechnician}}
            <li><a href="/reserve-for-student" data-testid="link-reserve-for-student"><i class="fa-solid fa-plus"></i> <span>Reserve for Student</span></a></li>
            {{/if}}
            <li><a href="/manage-reservations" class="active" data-testid="link-manage-reservations"><i class="fa-regular fa-clipboard"></i> <span>Manage Reservations</span></a></li>
            
            {{#if user.isTechnician}}
            <li><a href="/manage-no-shows" data-testid="link-manage-no-shows"><i class="fa-solid fa-user-xmark"></i> <span>Manage No-Shows</span></a></li>
            {{/if}}
        </ul>

        <div class="navbar-logout">
            <a href="/logout" data-testid="link-logout"><i class="fa-solid fa-right-from-bracket"></i> <span>Log out</span></a>
        </div>
    </aside>

    <div class="main-content">
        <div class="top-bar">
            <div class="top-bar-left">
                <h1>Manage Reservations</h1>
            </div>
            <div class="top-bar-right" onclick="location.href='/user-profile'">
                <div class="user-info">
                    <div class="user-name" data-testid="text-user-name">{{user.firstName}} {{user.lastName}}</div>
                    <div class="user-role" data-testid="text-user-role">{{user.role}}</div>
                </div>
                <div class="user-avatar" data-testid="user-avatar">{{user.initials}}</div>
            </div>
        </div>

        <div class="main-body">
            <div class="filter-bar">
                <label for="filter-status">Status:</label>
                <select id="filter-status" data-testid="select-filter-status">
                    <option value="all">All</option>
                    <option value="confirmed">Confirmed</option>
                    <option value="completed">Completed</option>
                    <option value="cancelled">Cancelled</option>
                </select>

                <label for="filter-date">Date:</label>
                <input type="date" id="filter-date" data-testid="input-filter-date">

                <div class="search-input">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="search-room" placeholder="Search room..." data-testid="input-search-room">
                </div>
            </div>

            <div class="table-wrapper">
                <table class="reservations-table" data-testid="table-reservations">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Room</th>
                            <th>Seat</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Purpose</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reservations-body" data-testid="tbody-reservations">
                        {{#each reservations}}
                        <tr data-status="{{status}}" data-testid="row-reservation-{{reservationId}}">
                            <td><span class="reservation-id">{{reservationId}}</span></td>
                            <td>{{reservedBy}}</td>
                            <td>{{lab.labName}} - {{lab.building}}</td>
                            <td>{{seatNumber}}</td>
                            <td>{{dateDisplay}}</td>
                            <td>{{timeDisplay}}</td>
                            <td>{{purpose}}</td>
                            <td>
                                <span class="status-badge status-{{status}}">
                                    {{statusLabel}}
                                </span>
                            </td>
                            <td>
                                <div class="actions-cell">
                                    {{#if canEdit}}
                                        <a href="/edit-reservation/{{reservationId}}" class="btn-action btn-edit" data-testid="button-edit-{{reservationId}}">
                                            <i class="fa-solid fa-pen"></i> View/Edit
                                        </a>
                                    {{/if}}

                                    {{#if canCancel}}
                                        <button class="btn-action btn-cancel" data-testid="button-cancel-{{reservationId}}" onclick="openCancelModal('{{reservationId}}')">
                                            <i class="fa-solid fa-xmark"></i> Cancel
                                        </button>
                                    {{/if}}

                                    {{#if canMarkArrived}}
                                        <form method="POST" action="/reservations/{{_id}}/arrived" style="display:inline;">
                                            <button type="submit" class="btn-action btn-view" data-testid="button-arrived-{{reservationId}}">
                                                <i class="fa-solid fa-check"></i> Arrived
                                            </button>
                                        </form>
                                    {{/if}}

                                    {{#if canMarkNoShow}}
                                        <form method="POST" action="/reservations/{{_id}}/no-show" style="display:inline;">
                                            <button type="submit" class="btn-action btn-cancel" data-testid="button-no-show-{{reservationId}}">
                                                <i class="fa-solid fa-user-xmark"></i> No Show
                                            </button>
                                        </form>
                                    {{/if}}

                                    {{#unless canEdit}}{{#unless canCancel}}{{#unless canMarkArrived}}{{#unless canMarkNoShow}}
                                        <span class="text-muted">—</span>
                                    {{/unless}}{{/unless}}{{/unless}}{{/unless}}
                                </div>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>

                <div id="empty-state" class="empty-state" data-testid="empty-state" {{#if hasReservations}}style="display:none;"{{/if}}>
                    <i class="fa-solid fa-calendar-xmark" style="font-size: 48px; color: var(--sage-green); margin-bottom: 12px;"></i>
                    <p>No reservations found matching your filters.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="cancel-modal" class="modal-overlay">
    <div class="modal">
        <i class="fa-solid fa-triangle-exclamation" style="font-size: 40px; color: var(--deepest-green); margin-bottom: 12px;"></i>
        <h3>Cancel Reservation</h3>
        <p id="cancel-modal-text">Are you sure you want to cancel this reservation?</p>
        <div class="modal-actions">
            <button class="btn-secondary" onclick="closeCancelModal()" data-testid="button-cancel-modal-no">No, Keep It</button>
            <button class="btn-danger" onclick="confirmCancel()" data-testid="button-cancel-modal-yes">Yes, Cancel</button>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

<script src="/js/reservation.js"></script>
<script src="/js/manage-reservations.js"></script>