<link rel="stylesheet" href="/css/reservation.css">

<div class="app-layout">
    <aside class="navbar">
        <a href="/dashboard" class="navbar-brand">
            <i class="fa-solid fa-building-columns"></i>
            <span>LabMate</span>
        </a>

        <ul class="navbar-nav" data-testid="navbar-nav">
            <li><a href="/dashboard" data-testid="link-dashboard"><i class="fa-solid fa-house"></i> <span>Dashboard</span></a></li>
            {{#unless user.isTechnician}}
            <li><a href="/slot-availability" data-testid="link-lab-availability"><i class="fa-solid fa-magnifying-glass"></i> <span>Lab Availability</span></a></li>
            {{/unless}}
            {{#if user.isTechnician}}
            <li><a href="/reserve-for-student" data-testid="link-reserve-for-student"><i class="fa-solid fa-plus"></i> <span>Reserve for Student</span></a></li>
            {{/if}}
            <li><a href="/manage-reservations" data-testid="link-manage-reservations"><i class="fa-regular fa-clipboard"></i> <span>Manage Reservations</span></a></li>
            {{#if user.isTechnician}}
            <li><a href="/manage-no-shows" class="active" data-testid="link-manage-no-shows"><i class="fa-solid fa-user-xmark"></i> <span>Manage No-Shows</span></a></li>
            {{/if}}
        </ul>

        <div class="navbar-logout">
            <a href="/login" data-testid="link-logout"><i class="fa-solid fa-right-from-bracket"></i> <span>Log out</span></a>
        </div>
    </aside>

    <div class="main-content">
        <div class="top-bar">
            <div class="top-bar-left">
                <h1>No-Show Management</h1>
                <div class="date-text">
                    <i class="fa-solid fa-shield-halved"></i> {{user.role}} Panel
                </div>
            </div>
            <div class="top-bar-right" onclick="location.href='/user-profile'">
                <div class="user-info">
                    <div class="user-name" data-testid="text-user-name">
                        {{user.firstName}} {{user.lastName}}
                    </div>
                    <div class="user-role" data-testid="text-user-role">
                        {{user.role}}
                    </div>
                </div>
                <div class="user-avatar" data-testid="user-avatar">
                    {{user.initials}}
                </div>
            </div>
        </div>

        <div class="main-body">
            <div class="stats-row" data-testid="stats-row">
                <div class="stat-card danger">
                    <div class="stat-number" data-testid="stat-total-noshows">{{noShows.length}}</div>
                    <div class="stat-label">Total No-Shows</div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-number" data-testid="stat-pending-noshows">{{noShows.length}}</div>
                    <div class="stat-label">Pending Review</div>
                </div>
            </div>

            <div class="filter-bar">
                <label for="filter-noshow-status">Status:</label>
                <select id="filter-noshow-status" data-testid="select-filter-noshow-status">
                    <option value="all">All</option>
                    <option value="no-show">No-Show</option>
                    <option value="resolved">Resolved</option>
                </select>

                <div class="search-input">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="search-noshow" placeholder="Search by student or room..." data-testid="input-search-noshow">
                </div>
            </div>

            <div class="table-wrapper">
                <table class="reservations-table" data-testid="table-noshows">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Student</th>
                            <th>Room</th>
                            <th>Seat</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Status</th>
                            <th>Penalty</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="noshows-body" data-testid="tbody-noshows">
                        {{#if hasNoShows}}
                            {{#each noShows}}
                            <tr data-status="no-show" data-testid="row-noshow-{{reservationId}}">
                                <td><span class="reservation-id">{{reservationId}}</span></td>
                                <td>
                                    {{reservedBy}}
                                    {{#if user.email}}
                                        <div class="no-show-details">{{reservedByEmail}}</div>
                                    {{/if}}
                                </td>
                                <td>{{lab.labName}} - {{lab.building}}</td>
                                <td>{{seatNumber}}</td>
                                <td>{{dateDisplay}}</td>
                                <td>{{timeDisplay}}</td>
                                <td>
                                    <span class="status-badge status-no-show">{{statusLabel}}</span>
                                </td>
                                <td>-</td>
                                <td>
                                    <div class="actions-cell">
                                        <form method="POST" action="/no-shows/{{_id}}/resolve" style="display:inline;">
                                            <button type="submit" class="btn-action btn-resolve" data-testid="button-resolve-{{reservationId}}">
                                                <i class="fa-solid fa-check"></i> Resolve
                                            </button>
                                        </form>
                                        
                                        <form method="POST" action="/no-shows/{{_id}}/flag" style="display:inline;">
                                            <button type="submit" class="btn-action btn-cancel" data-testid="button-flag-{{reservationId}}">
                                                <i class="fa-solid fa-flag"></i> Flag User
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {{/each}}
                        {{/if}}
                    </tbody>
                </table>

                <div id="empty-state" class="empty-state" {{#if hasNoShows}}style="display: none;"{{/if}} data-testid="noshow-empty-state">
                    <i class="fa-solid fa-calendar-xmark" style="font-size: 48px; color: var(--sage-green); margin-bottom: 12px;"></i>
                    <p>No records found matching your filters.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="resolve-modal" class="modal-overlay">
    <div class="modal">
        <i class="fa-solid fa-clipboard-check" style="font-size: 40px; color: var(--pine-green); margin-bottom: 12px;"></i>
        <h3>Resolve No-Show</h3>
        <p id="resolve-modal-text">Mark this no-show as resolved? The student will be notified.</p>
        <div class="form-group" style="text-align: left; margin-bottom: 16px;">
            <label for="resolve-notes">Resolution Notes</label>
            <textarea id="resolve-notes" data-testid="textarea-resolve-notes" rows="2" placeholder="e.g. Student provided valid excuse, First offense warning..."></textarea>
        </div>
        <div class="modal-actions">
            <button class="btn-secondary" type="button" onclick="closeResolveModal()" data-testid="button-resolve-cancel">Cancel</button>
            <button class="btn-primary" type="button" onclick="confirmResolve()" data-testid="button-resolve-confirm">Resolve</button>
        </div>
    </div>
</div>

<div id="flag-modal" class="modal-overlay">
    <div class="modal">
        <i class="fa-solid fa-flag" style="font-size: 40px; color: var(--dark-green); margin-bottom: 12px;"></i>
        <h3>Flag User</h3>
        <p id="flag-modal-text">Flag this user for repeated no-shows? This may restrict their booking privileges.</p>
        <div class="modal-actions">
            <button class="btn-secondary" type="button" onclick="closeFlagModal()" data-testid="button-flag-cancel">Cancel</button>
            <button class="btn-flag" type="button" onclick="confirmFlag()" data-testid="button-flag-confirm">Flag User</button>
        </div>
    </div>
</div>

<div id="remove-modal" class="modal-overlay">
    <div class="modal">
        <i class="fa-solid fa-trash" style="font-size: 40px; color: var(--deepest-green); margin-bottom: 12px;"></i>
        <h3>Remove No-Show Record</h3>
        <p id="remove-modal-text">Are you sure you want to remove this no-show record? This action cannot be undone.</p>
        <div class="modal-actions">
            <button class="btn-secondary" type="button" onclick="closeRemoveModal()" data-testid="button-remove-cancel">Cancel</button>
            <button class="btn-danger" type="button" onclick="confirmRemove()" data-testid="button-remove-confirm">Remove</button>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

<script src="/js/reservation.js"></script>
<script src="/js/manage-no-shows.js"></script>