<link rel="stylesheet" href="/css/auth.css">

<div class="register-container">

    <div class="register-left">
        <img src="../assets/images/ls_hall.png" alt="St. La Salle Hall">
    </div>

    <div class="register-right">
        <div class="logo-section">
            <h1>LabMate</h1>
        </div>

        <div class="form-container">
            <h1 class="form-title">Sign Up</h1>

            <form class="register-form" action="/register" method="POST">
                <div class="form-row">
                    <div class="form-input">
                        <label for="fName">First Name *</label>
                        <input type="text" id="fName" name="firstName" placeholder="John" required maxlength="40">
                    </div>

                    <div class="form-input">
                        <label for="lName">Last Name *</label>
                        <input type="text" id="lName" name="lastName" placeholder="Doe" required maxlength="40">
                    </div>
                </div>

                <div class="form-input">
                    <label for="email">Email *</label>
                    <input type="email" id="email" name="email" placeholder="john_doe@dlsu.edu.ph" required
                        maxlength="40">
                </div>

                <div class="form-input">
                    <label for="password">Password *</label>

                    <div class="password-container">
                        <input type="password" id="password" name="password" placeholder="Please use a strong password"
                            required maxlength="20">

                        <span class="toggle-password">
                            <i class="fa-solid fa-eye-slash" id="eye-icon" onclick="togglePassword()"></i>
                        </span>
                    </div>
                </div>

                <div class="form-input">
                    <label for="accType">Account Type *</label>

                    <select id="accType" name="role">
                        <option value="">-- Select your Account Type --</option>
                        <option value="Student">Student</option>
                        <option value="Lab Technician">Lab Technician</option>
                    </select>
                </div>

                <div class="btn-container">
                    <button type="submit" class="btn btn-gradient" onclick="goToLogin()">Create an Account</button>

                    <p class="form-footer">
                        Already have an account? <a href="/login"><i>Log in!</i></a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="/js/auth.js"></script>